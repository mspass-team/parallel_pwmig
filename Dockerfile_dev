FROM ghcr.io/mspass-team/mspass:latest

LABEL maintainer="Ian Wang <yinzhi.wang.cug@gmail.com>"
ENV PFPATH=/test/pf

USER root

# 1. Install build tools via apt (standard for all C++ builds)
RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# 2. Use Conda to install NumPy and Python development headers
# This ensures the headers are in /opt/conda/include/python3.10/
RUN conda install -y -c conda-forge numpy python-devel

# 3. Add your source code
ADD cxx /parallel_pwmig/cxx
ADD data /parallel_pwmig/data
ADD setup.py /parallel_pwmig/setup.py
ADD python /parallel_pwmig/python

# 4. Build and install your project
# Use --no-build-isolation to ensure it uses the Conda-installed NumPy headers
RUN MSPASS_HOME=/usr/local pip3 install -C--global-option=build -C--global-option=--debug /parallel_pwmig -v

RUN pip3 install vtk
